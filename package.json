{
  "name": "mirage-langchain",
  "description": "LangChain adapter for Mirage AI.",
  "version": "1.0.0",
  "homepage": "https://github.com/mirage-ai-com/mirage-langchain",
  "license": "MIT",
  "author": {
    "name": "Baptiste Jamin",
    "email": "baptiste@crisp.chat"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/mirage-ai-com/mirage-langchain.git"
  },
  "licenses": [
    {
      "type": "MIT",
      "url": "https://github.com/mirage-ai-com/mirage-langchain/blob/master/LICENSE"
    }
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">= 16.0.0"
  },
  "scripts": {
    "build": "npx tsc && npx tsc-alias && node -e \"const fs=require('fs');const f='dist/index.js';const v=require('./package.json').version;fs.writeFileSync(f, fs.readFileSync(f,'utf8').replace(/__PKG_VERSION_PLACEHOLDER__/g,v));\"",
    "test": "eslint lib && npm run build && istanbul cover _mocha",
    "coveralls": "npm run build && istanbul cover _mocha --report lcovonly && cat ./coverage/lcov.info | coveralls"
  },
  "dependencies": {
    "mirage-api": "^2.0.9",
    "zod-to-json-schema": "^3.25.2"
  },
  "peerDependencies": {
    "@langchain/core": ">=1.0.0"
  },
  "devDependencies": {
    "@langchain/core": "1.1.38",
    "@types/node": "22.13.10",
    "@typescript-eslint/eslint-plugin": "8.39.1",
    "coveralls": "2.13.1",
    "eslint": "9.29.0",
    "eslint-plugin-crisp": "1.1.13",
    "eslint-plugin-jsdoc": "54.1.0",
    "globals": "15.15.0",
    "istanbul": "0.4.5",
    "mocha": "3.5.0",
    "mocha-lcov-reporter": "1.3.0",
    "tsc-alias": "1.8.16",
    "typescript": "5.9.2"
  },
  "keywords": [
    "langchain",
    "mirage",
    "ai",
    "llm",
    "embeddings",
    "chat"
  ]
}
