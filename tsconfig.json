{
  "include": ["lib/**/*.ts"],
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist/",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2020",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["lib/*"]
    }
  }
}
